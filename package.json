{
  "name": "reader-skill",
  "version": "0.1.0",
  "description": "CLI + skill contract to read X posts/threads into structured, LLM-friendly text.",
  "type": "module",
  "bin": {
    "reader-skill": "dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.5.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
